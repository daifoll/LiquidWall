    "help.ai_dev_credit": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Built with AI-assisted development (vibe coding) using the Fable 5 model in Cursor."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Создано с помощью AI-разработки (vibe coding) с использованием модели Fable 5 в Cursor."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
