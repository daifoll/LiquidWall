        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Entwickelt mit KI-gestützter Entwicklung (Vibe Coding) unter Verwendung des Fable-5-Modells in Cursor."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desarrollado con desarrollo asistido por IA (vibe coding) usando el modelo Fable 5 en Cursor."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Desenvolvido com desenvolvimento assistido por IA (vibe coding) usando o modelo Fable 5 no Cursor."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Développé avec une assistance IA (vibe coding) grâce au modèle Fable 5 dans Cursor."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Cursor의 Fable 5 모델을 사용한 AI 지원 개발(vibe coding)로 제작되었습니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
