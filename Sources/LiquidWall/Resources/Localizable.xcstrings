    "onboarding.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Thousands of free videos and images for wallpapers.\nYou only need a free API key — it takes a couple of minutes."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Тысячи бесплатных видео и изображений для обоев.\nНужен только бесплатный API-ключ — это займёт пару минут."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "数千张免费视频和图像可用于壁纸。\n您只需一个免费的 API 密钥——只需几分钟即可获取。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "壁紙用の無料動画・画像が数千点。\n無料のAPIキーがあればOK — 数分で取得できます。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Tausende kostenlose Videos und Bilder für Hintergrundbilder.\nDu brauchst nur einen kostenlosen API-Schlüssel — dauert nur ein paar Minuten."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Miles de vídeos e imágenes gratuitas para fondos de pantalla.\nSolo necesitas una clave API gratuita — te llevará un par de minutos."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Milhares de vídeos e imagens gratuitos para papéis de parede.\nVocê só precisa de uma chave de API gratuita — leva apenas alguns minutos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Des milliers de vidéos et images gratuites pour vos fonds d'écran.\nIl vous suffit d'une clé API gratuite — cela ne prend que quelques minutes."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "배경화면용 무료 동영상과 이미지가 수천 개.\n무료 API 키만 있으면 됩니다 — 몇 분이면 충분합니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Tysiące darmowych filmów i obrazów na tapety.\nWystarczy darmowy klucz API — zajmie to kilka minut."
          }
        }
      }
