    "help.notes.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "• The wallpaper is not visible over full-screen apps.\n• Media provided by Pixabay under the Pixabay Content License."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "• Обои не видны поверх полноэкранных приложений.\n• Медиа предоставлены Pixabay по лицензии Pixabay Content License."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "• 壁纸在全屏应用上方不可见。\n• 媒体内容由 Pixabay 根据 Pixabay Content License 提供。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "• 壁紙はフルスクリーンアプリの上では表示されません。\n• メディアはPixabay Content LicenseのもとPixabayが提供しています。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "• Das Hintergrundbild ist über Vollbild-Apps nicht sichtbar.\n• Medien bereitgestellt von Pixabay unter der Pixabay Content License."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "• El fondo de pantalla no es visible sobre aplicaciones a pantalla completa.\n• Contenido multimedia proporcionado por Pixabay bajo la Licencia de Contenido de Pixabay."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "• O papel de parede não fica visível sobre aplicativos em tela cheia.\n• Mídia fornecida por Pixabay sob a Pixabay Content License."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "• Le fond d'écran n'est pas visible par-dessus les applications en plein écran.\n• Médias fournis par Pixabay sous la licence Pixabay Content License."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "• 배경화면은 전체 화면 앱 위에서는 보이지 않습니다.\n• 미디어는 Pixabay Content License에 따라 Pixabay에서 제공합니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "• Tapeta nie jest widoczna nad aplikacjami pełnoekranowymi.\n• Media dostarczone przez Pixabay na licencji Pixabay Content License."
          }
        }
      }
    },
