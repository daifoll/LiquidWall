    "help.power.body": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Playback pauses automatically when the desktop is fully covered by windows or a full-screen app, when the screen is locked, and during sleep. The wallpaper never prevents your display from sleeping."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Воспроизведение автоматически приостанавливается, когда рабочий стол полностью закрыт окнами или полноэкранным приложением, при блокировке экрана и во время сна. Обои никогда не мешают отключению дисплея."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当桌面被窗口或全屏应用完全覆盖、屏幕锁定时以及睡眠期间，播放会自动暂停。壁纸绝不会阻止显示器进入睡眠。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "デスクトップがウィンドウやフルスクリーンアプリで完全に覆われたとき、画面がロックされたとき、スリープ中に再生は自動的に一時停止します。壁紙がディスプレイのスリープを妨げることはありません。"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Wiedergabe wird automatisch pausiert, wenn der Desktop vollständig von Fenstern oder einer Vollbild-App bedeckt ist, wenn der Bildschirm gesperrt ist und im Ruhezustand. Das Hintergrundbild verhindert niemals, dass dein Display in den Schlafmodus wechselt."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La reproducción se pausa automáticamente cuando el escritorio está completamente cubierto por ventanas o una aplicación a pantalla completa, cuando la pantalla está bloqueada y durante el modo de suspensión. El fondo de pantalla nunca impide que tu pantalla se apague."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A reprodução é pausada automaticamente quando a área de trabalho está totalmente coberta por janelas ou um aplicativo em tela cheia, quando a tela está bloqueada e durante o sono. O papel de parede nunca impede que a tela entre em modo de suspensão."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La lecture s'interrompt automatiquement lorsque le bureau est entièrement recouvert par des fenêtres ou une application en plein écran, lorsque l'écran est verrouillé et pendant la veille. Le fond d'écran n'empêche jamais votre écran de se mettre en veille."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "데스크톱이 창이나 전체 화면 앱에 완전히 가려지거나, 화면이 잠기거나, 절전 중일 때 재생이 자동으로 일시 정지됩니다. 배경화면은 디스플레이가 절전 모드로 들어가는 것을 방해하지 않습니다."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Odtwarzanie jest automatycznie wstrzymywane, gdy pulpit jest w pełni zakryty oknami lub aplikacją pełnoekranową, gdy ekran jest zablokowany oraz podczas uśpienia. Tapeta nigdy nie uniemożliwia przejścia wyświetlacza w tryb uśpienia."
          }
        }
      }
    },
